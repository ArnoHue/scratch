.github/copilot-instructions.md
./chess/logs
chess/releases

# Local skill/runtime temp output (keep generated artifacts out of SCM)
chess/.skill_tmp/
chess/data/_local/
!chess/.skill_tmp/.gitkeep
!chess/data/_local/.gitkeep

# Local bulk workspace folders
tools/
chess/test_harness/scratch-vm-src/

# Common generated artifacts
**/__pycache__/
*.pyc

# Node dependency trees generated by local tooling
tools/node_modules/
chess/test_harness/scratch-vm-src/node_modules/

# Data-folder noise: logs, dated batches, local test assets
chess/data/*
# Baselines are local run artifacts in this workspace; keep ignored.
chess/data/log/
chess/data/log*/
chess/data/logs*/
chess/data/logs*
chess/data/[0-9][0-9][0-9][0-9]*/
chess/data/[0-9][0-9][0-9][0-9]*
chess/data/engines/
chess/data/games*/
chess/data/pgns/
chess/data/js/
chess/data/element/
chess/data/wd/
chess/data/tw_tuning/
chess/data/nnue_iir/

# Scratch data/runtime leftovers
chess/data/*.scratch
chess/data/*.txt

# Skill-generated tuning artifacts in improvement folders
chess/data/classic_improvements/*.sb3
chess/data/classic_improvements/*.json
chess/data/nnue_improvements/*.sb3
chess/data/nnue_improvements/*.json

# Keep improvement folders lightweight in SCM: only README is expected by default
chess/data/classic_improvements/*
!chess/data/classic_improvements/README.md
chess/data/nnue_improvements/*
!chess/data/nnue_improvements/README.md

# Test harness runtime outputs (configs/results/logs/temp)
chess/test_harness/.tmp*
chess/test_harness/_tmp*
chess/test_harness/_run*.log
chess/test_harness/_probe.log
chess/test_harness/_search_*.txt
chess/test_harness/*_result*.json
chess/test_harness/*_config*.json
chess/test_harness/*_compare_report*.json
chess/test_harness/*_diagnostic*.json
chess/test_harness/*_logfiles/
chess/test_harness/*_logs/
chess/test_harness/game_automation_outputs/
chess/test_harness/online_fen_sources/

# Root chess generated engine artifacts
chess/GoK_Chess_*.sb3

# Local helper scripts/configs at chess root
chess/*.py
chess/*.js
chess/*.json
chess/*.txt
chess/*.log

# Test harness is local tooling workspace; ignore script/config/result artifacts
chess/test_harness/**/*.py
chess/test_harness/**/*.js
chess/test_harness/**/*.json
chess/test_harness/**/*.txt
chess/test_harness/**/*.log
chess/test_harness/**/*.md
chess/test_harness/**/*.pgn